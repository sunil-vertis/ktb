{
  "name": "opti-masterclass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -r ./scripts/node-tls-prelude.cjs ./node_modules/next/dist/bin/next dev",
    "dev:inspect": "cross-env NODE_OPTIONS='--inspect' node -r ./scripts/node-tls-prelude.cjs ./node_modules/next/dist/bin/next dev",
    "build": "node -r ./scripts/node-tls-prelude.cjs ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "gen-types": "node -r ./scripts/node-tls-prelude.cjs ./node_modules/@graphql-codegen/cli/cjs/bin.js --config ./codegen.cjs && node ./scripts/dedupe-codegen-output.mjs"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@sendgrid/mail": "^8.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "negotiator": "^1.0.0",
    "next": "^15.2.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@graphql-codegen/cli": "^5.0.4",
    "@graphql-codegen/typescript": "^4.1.3",
    "@graphql-codegen/typescript-generic-sdk": "^4.0.1",
    "@graphql-codegen/typescript-operations": "^4.4.1",
    "@types/negotiator": "^0.6.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^9",
    "eslint-config-next": "15.2.8",
    "lint-staged": "^15.4.3",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sass": "^1.99.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
